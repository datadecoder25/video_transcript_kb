  "sentiment_analysis_results": [
    {
      "sentiment": "NEUTRAL",
      "speaker": "A",
      "text": "Hi, Eric.",
      "start": 160,
      "end": 720,
      "confidence": 0.66142935
    },
    {
      "sentiment": "NEUTRAL",
      "speaker": "A",
      "text": "I am recording this to show you where you can find the listing.",
      "start": 880,
      "end": 4520,
      "confidence": 0.8746846
    },
    {
      "sentiment": "NEUTRAL",
      "speaker": "A",
      "text": "So after you log in, go to Inventory and then manage all inventory.",
      "start": 4520,
      "end": 9120,
      "confidence": 0.87126046
    },
    {
      "sentiment": "NEUTRAL",
      "speaker": "A",
      "text": "And then you will see this listing.",
      "start": 9360,
      "end": 11120,
      "confidence": 0.8110092
    },
    {
      "sentiment": "NEUTRAL",
      "speaker": "A",
      "text": "It's right here.",
      "start": 11120,
      "end": 12080,
      "confidence": 0.6439585
    },
    {
      "sentiment": "NEUTRAL",
      "speaker": "A",
      "text": "Okay.",
      "start": 13920,
      "end": 14560,
      "confidence": 0.58435184
    },
    {
      "sentiment": "NEUTRAL",
      "speaker": "A",
      "text": "And I think you may have clicked on FBA Inventory.",
      "start": 14640,
      "end": 18720,
      "confidence": 0.7870645
    },
    {
      "sentiment": "NEUTRAL",
      "speaker": "A",
      "text": "Maybe that's why you couldn't see it, because it's not an FBM listing at this point.",
      "start": 19120,
      "end": 23360,
      "confidence": 0.6073283
    },
    {
      "sentiment": "NEUTRAL",
      "speaker": "A",
      "text": "You need to convert it to a BM change to Fulfilled by Amazon.",
      "start": 23360,
      "end": 27130,
      "confidence": 0.8366418
    },
    {
      "sentiment": "NEUTRAL",
      "speaker": "A",
      "text": "So if you go to manage all inventory, it will show up.",
      "start": 27530,
      "end": 31370,
      "confidence": 0.8564114
    },
    {
      "sentiment": "NEUTRAL",
      "speaker": "A",
      "text": "All right.",
